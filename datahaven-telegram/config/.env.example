# Datahaven Telegram Bot Configuration

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Datahaven paths
DATAHAVEN_HOME=/opt/spaceos/datahaven
DATAHAVEN_CORE=/home/gabor/datahaven-core

# Knowledge Service
KNOWLEDGE_URL=http://localhost:3456

# Bot identity (daemon ID in message queue)
BOT_DAEMON_ID=telegram-bot

# Authorized Telegram user IDs (comma-separated)
# Get your ID: send /start to @userinfobot
ALLOWED_USERS=123456789

# Admin users (can send to any daemon)
ADMIN_USERS=123456789

# Notification settings
NOTIFY_ON_DONE=true
NOTIFY_ON_BLOCKED=true
NOTIFY_ON_CRITICAL=true

# Poll interval for inbox check (seconds)
POLL_INTERVAL=30

# Logging
LOG_LEVEL=INFO
