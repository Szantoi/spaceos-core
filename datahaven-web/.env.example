# Datahaven Web Dashboard Configuration

# Server
PORT=3457
HOST=0.0.0.0

# Datahaven paths
DATAHAVEN_HOME=/opt/spaceos/datahaven
MESSAGES_DB=/opt/spaceos/datahaven/messages.db

# Knowledge Service
KNOWLEDGE_URL=http://localhost:3456

# Authentication (optional)
AUTH_ENABLED=false
AUTH_TOKEN=your-secret-token

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
