{
  "name": "datahaven-web",
  "version": "1.0.0",
  "description": "Web dashboard for Datahaven - daemon monitoring, messaging, and knowledge search",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
