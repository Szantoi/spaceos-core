{
  "name": "spaceos-knowledge-service",
  "version": "1.0.0",
  "description": "SpaceOS Nexus — RAG knowledge service (local embed + optional Voyage AI + ChromaDB)",
  "type": "commonjs",
  "scripts": {
    "preinstall": "echo '📦 Using npm cache at ~/.npm (MSG-NEXUS-011)'",
    "ci": "npm ci --prefer-offline --cache ~/.npm",
    "build": "tsc",
    "build:cached": "../../scripts/build-cached.sh .",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "index": "ts-node src/indexer.ts",
    "validate": "./scripts/validate-imports.sh",
    "test": "vitest run --reporter=verbose",
    "test:parallel": "vitest run --pool=threads --reporter=dot",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run src/__tests__/unit",
    "test:integration": "vitest run src/__tests__/integration",
    "test:e2e": "vitest run src/__tests__/e2e"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/textsplitters": "^1.0.1",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.11.1",
    "chokidar": "^5.0.0",
    "chromadb": "^3.3.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "isomorphic-dompurify": "^3.18.0",
    "js-yaml": "^5.0.0",
    "sharp": "^0.35.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
