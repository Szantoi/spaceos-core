<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>false</AllowUnsafeBlocks>
    <IsPackable>false</IsPackable>
    <!-- Benchmarks must be excluded from dotnet test discovery -->
    <IsTestProject>false</IsTestProject>
    <!-- Suppress version inheritance from Directory.Build.props for the benchmark entry point -->
    <Version>0.0.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BenchmarkDotNet" Version="0.14.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\SpaceOS.Cabinet.Construction\SpaceOS.Cabinet.Construction.csproj" />
    <ProjectReference Include="..\..\src\SpaceOS.Cabinet.Domain\SpaceOS.Cabinet.Domain.csproj" />
    <ProjectReference Include="..\..\src\SpaceOS.Cabinet.Geometry\SpaceOS.Cabinet.Geometry.csproj" />
    <ProjectReference Include="..\..\src\SpaceOS.Cabinet.Abstractions\SpaceOS.Cabinet.Abstractions.csproj" />
    <ProjectReference Include="..\..\src\SpaceOS.Cabinet.Machining\SpaceOS.Cabinet.Machining.csproj" />
  </ItemGroup>

</Project>
