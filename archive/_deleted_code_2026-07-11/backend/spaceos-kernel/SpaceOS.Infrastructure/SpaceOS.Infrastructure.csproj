  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
      <_Parameter1>SpaceOS.Kernel.Tests</_Parameter1>
    </AssemblyAttribute>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
      <_Parameter1>SpaceOS.Kernel.IntegrationTests</_Parameter1>
    </AssemblyAttribute>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
      <_Parameter1>SpaceOS.Kernel.Api.Tests</_Parameter1>
    </AssemblyAttribute>
    <!-- Castle DynamicProxy (Moq) requires this to mock internal interfaces.
         Two entries: one for signed proxy assemblies, one for unsigned (PublicKeyToken=null). -->
