# ============================================================================
# SpaceOS Root repo (.gitignore) — 2026-04-30 restructured
# Ez a repo CSAK a docs/ + tools/ + .claude/ mappákat tartalmazza.
# A backend/ és frontend/ saját git repókkal rendelkeznek.
# ============================================================================

# Backend repos (saját git repo-juk van)
backend/

# Frontend repos (saját git repo-juk van)
frontend/

# Keycloak config
keycloak/

# Docker / runtime
docker-compose.yml
logs/

# Secrets / env
*.env
.mcp.json
scripts/email.conf
scripts/telegram.conf
scripts/.streak
scripts/.motivator-state
scripts/.tg-offset

# Build artifacts
*.bak
*.staged

# Nginx configs (managed separately)
nginx-*.conf

# Local NuGet
local-nuget/

# Claude local settings
.claude/settings.local.json

# Régi mappák (ha még lennének)
spaceos-kernel/
spaceos-orchestrator/
spaceos-modules-*/
spaceos-nesting-algorithms/
spaceos-freetier-api/
spaceos-freetier-portal/
spaceos-freetier/
spaceos-doorstar-portal/
spaceos-architect/
spaceos-librarian/
spaceos-partner-api/
spaceos-workers-identity/
design-portal/
e2e/
infra/
tester/
agent_tools/

# Node modules (all subdirs)
**/node_modules/
