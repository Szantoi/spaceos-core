# ── Embedding backend ────────────────────────────────────────────────────────
# Default: local all-MiniLM-L6-v2 (no API key needed, model downloads ~25MB on first run)
# Optional upgrade: set VOYAGE_API_KEY for voyage-3-lite (better semantic quality)
# Get key from: https://dash.voyageai.com/  (free tier available)
# VOYAGE_API_KEY=your_voyage_key_here

# ── ChromaDB ─────────────────────────────────────────────────────────────────
# Start with: docker compose up -d  (in /opt/spaceos/spaceos-nexus/)
# Port 8001 avoids conflict with existing postgres (5432) and pgadmin (5050)
CHROMA_URL=http://localhost:8001

# ── Knowledge base path ───────────────────────────────────────────────────────
# Default: /opt/spaceos/docs/knowledge (auto-detected from file location)
# KNOWLEDGE_BASE_PATH=/opt/spaceos/docs/knowledge

# ── Server port ───────────────────────────────────────────────────────────────
PORT=3456
