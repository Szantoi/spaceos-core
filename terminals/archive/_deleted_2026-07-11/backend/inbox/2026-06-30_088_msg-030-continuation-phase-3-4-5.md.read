### Phase 4: Domain Events ✅

**Feladat:** Implement domain event system for `QuoteRequestCreated`.

**1. Domain Event:**
```csharp
// Domain/Events/QuoteRequestCreated.cs
public record QuoteRequestCreated(
    Guid QuoteId,
    Guid TenantId,
    string CustomerEmail,
    string TrackingToken,
    DateTime CreatedAt
) : IDomainEvent;
```

**2. Aggregate Root (upgrade `PublicQuoteRequest`):**
```csharp
public class PublicQuoteRequest : AggregateRoot<Guid>
{
    // ... existing properties

    public static PublicQuoteRequest Create(...)
    {
        var request = new PublicQuoteRequest { ... };

        // Raise domain event
        request.RaiseDomainEvent(new QuoteRequestCreated(
            request.Id,
            request.TenantId,
            request.CustomerEmail,
            request.TrackingToken,
            request.CreatedAt
        ));

        return request;
    }
}
```

**3. Domain Event Dispatcher (infrastructure):**
```csharp
// Infrastructure/Events/DomainEventDispatcher.cs
public class DomainEventDispatcher : IDomainEventDispatcher
{
    private readonly IServiceProvider _serviceProvider;

    public async Task DispatchAsync(IDomainEvent domainEvent, CancellationToken ct)
    {
        var handlerType = typeof(IDomainEventHandler<>).MakeGenericType(domainEvent.GetType());
        var handlers = _serviceProvider.GetServices(handlerType);

        foreach (var handler in handlers)
        {
            await ((dynamic)handler).HandleAsync((dynamic)domainEvent, ct);
        }
    }
}
```

**4. UnitOfWork integration:**
```csharp
public class UnitOfWork : IUnitOfWork
{
    private readonly AppDbContext _context;
    private readonly IDomainEventDispatcher _eventDispatcher;

    public async Task<int> SaveChangesAsync(CancellationToken ct)
    {
        // Collect domain events from aggregates
        var domainEvents = _context.ChangeTracker
            .Entries<AggregateRoot<Guid>>()
            .SelectMany(e => e.Entity.DomainEvents)
            .ToList();

        // Save changes first
        var result = await _context.SaveChangesAsync(ct);

        // Dispatch events after successful save
        foreach (var domainEvent in domainEvents)
        {
            await _eventDispatcher.DispatchAsync(domainEvent, ct);
        }

        return result;
    }
}
```

**5. DI registration:**
```csharp
services.AddScoped<IDomainEventDispatcher, DomainEventDispatcher>();
services.AddScoped<IUnitOfWork, UnitOfWork>();
```

### Phase 5: Integration Tests ✅

**Feladat:** Integration tests for persistence + domain events.

**Test 1: Persistence works**
```csharp
[Fact]
public async Task CreateQuoteRequest_ShouldPersistToDatabase()
{
    // Arrange
    var handler = new CreateQuoteRequestHandler(...);
    var command = new CreateQuoteRequest("acme", "John", "john@acme.com", null, "Windows", 10);

    // Act
    var result = await handler.Handle(command, CancellationToken.None);

    // Assert
    result.IsSuccess.Should().BeTrue();
    var saved = await _repository.GetByIdAsync(result.Value, CancellationToken.None);
    saved.Should().NotBeNull();
    saved.CustomerName.Should().Be("John");
}
```

**Test 2: Domain event dispatched**
```csharp
[Fact]
public async Task CreateQuoteRequest_ShouldDispatchQuoteRequestCreatedEvent()
{
    // Arrange
    var eventHandlerMock = new Mock<IDomainEventHandler<QuoteRequestCreated>>();
    var handler = new CreateQuoteRequestHandler(..., eventHandlerMock.Object);
    var command = new CreateQuoteRequest("acme", "John", "john@acme.com", null, "Windows", 10);

    // Act
    var result = await handler.Handle(command, CancellationToken.None);

    // Assert
    eventHandlerMock.Verify(h => h.HandleAsync(
        It.Is<QuoteRequestCreated>(e => e.QuoteId == result.Value),
        It.IsAny<CancellationToken>()
    ), Times.Once);
}
```

**Test 3: End-to-end (API → persistence → event)**
```csharp
[Fact]
public async Task POST_PublicQuoteRequest_ShouldPersistAndDispatchEvent()
{
    // Arrange
    var client = _factory.CreateClient();
    var request = new { subdomain = "acme", customerName = "John", ... };

    // Act
    var response = await client.PostAsJsonAsync("/api/public/quote-requests", request);

    // Assert
    response.StatusCode.Should().Be(HttpStatusCode.Created);
    var quoteId = await response.Content.ReadFromJsonAsync<Guid>();

    var saved = await _repository.GetByIdAsync(quoteId, CancellationToken.None);
    saved.Should().NotBeNull();

    // Verify event was dispatched (check email handler was called, etc.)
}
```

